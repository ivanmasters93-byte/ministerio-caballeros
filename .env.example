# Database - SQLite for local dev
DATABASE_URL="file:./dev.db"

# NextAuth - generate a strong secret for production
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic AI (Claude)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Groq (Transcripcion de audio con Whisper + Resumen con Llama - tier gratuito)
# Obtén tu clave en https://console.groq.com
GROQ_API_KEY=""

# WhatsApp Integration
# Options: "mock" | "twilio" | "meta"
WHATSAPP_PROVIDER="mock"
WHATSAPP_API_KEY=""
WHATSAPP_PHONE_NUMBER_ID=""

# Canva — Generador de Flyers con IA
# Obtén tu token en https://www.canva.com/developers/
CANVA_API_TOKEN=""

# Web Push (VAPID keys for browser push notifications)
# Generate with: node -e "const wp = require('web-push'); console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@gedeones.com"

# Vercel Blob Storage (imagenes de anuncios/flyers)
# Se genera automaticamente al habilitar Blob en el proyecto Vercel
BLOB_READ_WRITE_TOKEN=""

# Cron Secret (protege endpoints cron de acceso no autorizado)
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""
