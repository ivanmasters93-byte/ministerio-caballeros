# === SUPABASE (PostgreSQL + Auth) ===
DATABASE_URL="postgresql://[user]:[password]@[host]:[5432]/[database]"
SUPABASE_URL="https://[project].supabase.co"
SUPABASE_ANON_KEY="[anon-key]"
SUPABASE_SERVICE_ROLE_KEY="[service-role-key]"

# === CLERK (Identity Management) ===
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="[clerk-publishable-key]"
CLERK_SECRET_KEY="[clerk-secret-key]"
CLERK_WEBHOOK_SECRET="[webhook-secret]"

# === SENTRY (Error Tracking & Monitoring) ===
NEXT_PUBLIC_SENTRY_DSN="[sentry-dsn]"
SENTRY_AUTH_TOKEN="[sentry-auth-token]"
SENTRY_ORG="[org-name]"
SENTRY_PROJECT="[project-name]"
SENTRY_ENVIRONMENT="production"

# === PostHog (Product Analytics) ===
NEXT_PUBLIC_POSTHOG_KEY="[posthog-api-key]"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# === Resend (Email Service) ===
RESEND_API_KEY="[resend-api-key]"
RESEND_FROM_EMAIL="noreply@ministerio-caballeros.example.com"

# === Pinecone (Vector Database) ===
PINECONE_API_KEY="[pinecone-api-key]"
PINECONE_INDEX_NAME="ministerio-caballeros"
PINECONE_ENVIRONMENT="[us-east-1-aws]"

# === Anthropic ===
ANTHROPIC_API_KEY="[anthropic-api-key]"

# === Application ===
NEXTAUTH_SECRET="[generate-with-openssl-rand-base64-32]"
NEXTAUTH_URL="https://ministerio-caballeros.example.com"
NEXT_PUBLIC_APP_URL="https://ministerio-caballeros.example.com"

# === WhatsApp (Mock or Real Provider) ===
WHATSAPP_PROVIDER="webhook" # 'mock' for development, 'webhook' for production
WHATSAPP_WEBHOOK_URL="https://ministerio-caballeros.example.com/api/webhooks/whatsapp"
WHATSAPP_VERIFY_TOKEN="[verify-token]"
WHATSAPP_API_VERSION="v18.0"
WHATSAPP_BUSINESS_PHONE_NUMBER_ID="[phone-number-id]"
WHATSAPP_BUSINESS_ACCOUNT_ID="[business-account-id]"
WHATSAPP_BUSINESS_ACCESS_TOKEN="[access-token]"

# === Feature Flags ===
FEATURE_AI_ASSISTANT="true"
FEATURE_WHATSAPP_INTEGRATION="true"
FEATURE_VECTOR_SEARCH="true"
